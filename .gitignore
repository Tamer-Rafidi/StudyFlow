cat > .gitignore << 'EOF'
# Dependencies
node_modules/
frontend/node_modules/

# Build outputs
dist/
frontend/dist/
frontend/build/
backend/dist/
backend/build/
*.spec

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv/
env/
.venv/

# Data files
uploads/
summaries/
flashcards/
exams/
*.db
*.sqlite

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Logs
*.log

# Environment
.env
.env.local

# OS
Thumbs.db
EOF